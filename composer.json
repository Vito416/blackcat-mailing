{
  "name": "blackcatacademy/blackcat-mailing",
  "description": "DB-backed notifications + SMTP mail worker for the BlackCat ecosystem.",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-pdo": "*",
    "psr/log": "^3.0",
    "phpmailer/phpmailer": "^6.9",
    "blackcatacademy/blackcat-core": "dev-dev",
    "blackcatacademy/blackcat-database": "dev-dev"
  },
  "autoload": {
    "psr-4": {
      "BlackCat\\Mailing\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BlackCat\\Mailing\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/mailing-worker"
  ],
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}

